#!/bin/bash
# Hook de Git para desplegar segnec.com.ar automáticamente
# Ubicación requerida: /srv/proyectos/segnec/hooks/post-receive

# Definir variables
TARGET="/var/www/segnec.com.ar"
GIT_DIR="/srv/proyectos/segnec"
BRANCH="main"

echo "=========================================================="
echo "Iniciando despliegue de Segnec a: $TARGET"
echo "=========================================================="

while read oldrev newrev ref
do
    # Verificar si el branch que se empuja es 'main'
    if [[ $ref = refs/heads/$BRANCH ]];
    then
        echo "Ejecutando checkout de la rama $BRANCH a $TARGET"
        
        # Checkout forzando la sobreescritura del directorio destino
        GIT_WORK_TREE=$TARGET git checkout -f $BRANCH
        
        echo "Cambiando propietario y permisos para Nginx (www-data)..."
        # Ajustar los permisos (requiere sudo sin passwd, si no saca esto o correr a mano)
        # sudo chown -R www-data:www-data $TARGET
        
        echo "Despliegue exitoso."
    else
        echo "Rama $ref omitida (solamente se despliega $BRANCH)."
    fi
done
